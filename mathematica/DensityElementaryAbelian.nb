28c7aca06f9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Memoized", " ", "recursive", " ", "definition", " ", "of", " ", "the", 
     " ", "total", " ", "number", " ", "of", " ", "subspaces", " ", "of", " ", 
     RowBox[{
      TemplateBox[<|"boxes" -> FormBox[
          SubsuperscriptBox[
           StyleBox["F", FontSlant -> "Plain"], 
           StyleBox["p", "TI"], 
           StyleBox["n", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
        "\\mathbb{F}_p^n", "state" -> "Boxes"|>,
       "TeXAssistantTemplate"], ".", " ", "Can"}], " ", "also", " ", "use", 
     " ", "a", " ", "more", " ", "direct", " ", "definition"}], ",", " ", 
    RowBox[{
     RowBox[{"like", "\[IndentingNewLine]", 
      RowBox[{"Subspaces", "[", 
       RowBox[{"p_", ",", "n_"}], "]"}]}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"QBinomial", "[", 
         RowBox[{"n", ",", "i", ",", "p"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}], 
      "\[IndentingNewLine]", "which", " ", "might", " ", "play", " ", "nicer",
       " ", "with", " ", "FunctionExpand", " ", "and", " ", "large", " ", 
      "values", " ", "of", " ", 
      RowBox[{"n", "."}]}]}]}], "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Subspaces", "[", 
     RowBox[{"p_", ",", "0"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Subspaces", "[", 
      RowBox[{"p", ",", "0"}], "]"}], "=", "1"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Subspaces", "[", 
     RowBox[{"p_", ",", "1"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Subspaces", "[", 
      RowBox[{"p", ",", "1"}], "]"}], "=", "2"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Subspaces", "[", 
     RowBox[{"p_", ",", "n_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Subspaces", "[", 
      RowBox[{"p", ",", "n"}], "]"}], "=", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"Subspaces", "[", 
        RowBox[{"p", ",", 
         RowBox[{"n", "-", "1"}]}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", "^", 
          RowBox[{"(", 
           RowBox[{"n", "-", "1"}], ")"}]}], "-", "1"}], ")"}], 
       RowBox[{"Subspaces", "[", 
        RowBox[{"p", ",", 
         RowBox[{"n", "-", "2"}]}], "]"}]}]}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NumZerosCpn", "[", 
     RowBox[{"p_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"QBinomial", "[", 
        RowBox[{"n", ",", "i", ",", "p"}], "]"}], 
       RowBox[{"QBinomial", "[", 
        RowBox[{
         RowBox[{"n", "-", "i"}], ",", "j", ",", "p"}], "]"}], 
       RowBox[{"QBinomial", "[", 
        RowBox[{
         RowBox[{"n", "-", "i", "-", "j"}], ",", "k", ",", "p"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Subspaces", "[", 
          RowBox[{"p", ",", 
           RowBox[{"j", "+", "k"}]}], "]"}], "-", 
         RowBox[{"Subspaces", "[", 
          RowBox[{"p", ",", "k"}], "]"}]}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", 
        RowBox[{"n", "-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{"n", "-", "i"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", 
        RowBox[{"n", "-", "i", "-", "j"}]}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NumRowsCpn", "[", 
     RowBox[{"p_", ",", "n_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"QBinomial", "[", 
        RowBox[{"n", ",", "i", ",", "p"}], "]"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Subspaces", "[", 
          RowBox[{"p", ",", 
           RowBox[{"n", "-", "i"}]}], "]"}], "-", "1"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", 
        RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CodensityCpn", "[", 
     RowBox[{"p_", ",", "n_"}], "]"}], ":=", 
    FractionBox[
     RowBox[{"NumZeroesCpn", "[", 
      RowBox[{"p", ",", "n"}], "]"}], 
     RowBox[{
      RowBox[{"NumRowsCpn", "[", 
       RowBox[{"p", ",", "n"}], "]"}], "^", "2"}]]}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.959278091924654*^9, 3.959278231593129*^9}, {
