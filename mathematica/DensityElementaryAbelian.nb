  3.9582401595257373`*^9, 3.95824024395595*^9}, {3.959278303421605*^9, 
  3.959278306098294*^9}, {3.9592783488625298`*^9, 3.959278408461553*^9}, {
  3.959278507224085*^9, 3.959278552055157*^9}, {3.959278592949731*^9, 
  3.9592785963496633`*^9}, {3.959278881120502*^9, 
