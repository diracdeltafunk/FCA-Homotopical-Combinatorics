  3.9592782640954638`*^9}},ExpressionUUID->"1b136b26-bda1-4d6e-b180-\
6fc6702146fa"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"NumZerosCpn", "[", 
   RowBox[{"p", ",", "n"}], "]"}]], "InlineCode",ExpressionUUID->
  "dd154ed0-0377-4223-b84b-04726146dee0"],
 " returns a formula for the number of 0\[CloseCurlyQuote]s in the reduced \
context matrix for the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Sub", FontSlant -> "Plain"], "(", 
         SubsuperscriptBox[
          StyleBox["C", "TI"], 
          StyleBox["p", "TI"], 
          StyleBox["n", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathsf{Sub}(C_p^n)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "62029cf0-9b9b-4d31-801b-98f3272b4d03"],
 "\n",
 Cell[BoxData[
  RowBox[{"NumRowsCpn", "[", 
   RowBox[{"p", ",", "n"}], "]"}]], "InlineCode",ExpressionUUID->
  "1ea1d320-df3b-457b-bb43-acf6d3eb7fda"],
 " returns a formula for the number of rows in the reduced context matrix for \
the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Sub", FontSlant -> "Plain"], "(", 
         SubsuperscriptBox[
          StyleBox["C", "TI"], 
          StyleBox["p", "TI"], 
          StyleBox["n", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathsf{Sub}(C_p^n)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4e8d1fa0-8580-48e2-a9c6-cbe91dc8317b"],
 "\n",
 Cell[BoxData[
  RowBox[{"CodensityCpn", "[", 
   RowBox[{"p", ",", "n"}], "]"}]], "InlineCode",ExpressionUUID->
  "0fd67a28-5d51-44d2-ae22-888a7d58820a"],
 " returns a formula for 1 minus the density of the reduced context matrix \
for the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Sub", FontSlant -> "Plain"], "(", 
         SubsuperscriptBox[
          StyleBox["C", "TI"], 
          StyleBox["p", "TI"], 
          StyleBox["n", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathsf{Sub}(C_p^n)", "state" -> "Boxes"|>,
