Cell[CellGroupData[{
Cell[TextData[{
 "Computing Densities for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], "1"], "]"}], "\[Cross]", "\[CenterEllipsis]",
          "\[Cross]", 
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], 
            StyleBox["k", "TI"]], "]"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "[n_1] \\times \\cdots \\times [n_k]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4ae7d7d7-c192-48f2-846a-4bd02a3beb31"]
}], "Title",
 CellChangeTimes->{{3.958239886924759*^9, 3.958239942876428*^9}, {
  3.958240098280129*^9, 3.958240153665036*^9}, {3.95927875564342*^9, 
  3.959278773503776*^9}},ExpressionUUID->"96adc7a1-0188-4a8b-af67-\
81ac0f4cbdde"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"NumZerosGrid", "[", "k", "]"}]], "InlineCode",ExpressionUUID->
  "aa25002f-8b17-479f-8365-d19515eb64fd"],
 " returns a formula for the number of 0\[CloseCurlyQuote]s in the reduced \
context matrix for the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], "1"], "]"}], "\[Cross]", "\[CenterEllipsis]",
          "\[Cross]", 
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], 
            StyleBox["k", "TI"]], "]"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "[n_1] \\times \\cdots \\times [n_k]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f858a5ac-49ce-4951-a109-d886c18b482b"],
 ", in terms of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "[", "1", "]"}], ",", "...", ",", 
    RowBox[{"n", "[", "k", "]"}]}], TraditionalForm]],ExpressionUUID->
  "608431fd-cd7b-416c-8534-5adaaebc7ad4"],
 "\n",
 Cell[BoxData[
  RowBox[{"NumRowsGrid", "[", "k", "]"}]], "InlineCode",ExpressionUUID->
  "2b0a9964-323a-4f93-ac1a-1bc91abe221f"],
 " returns a formula for the number of rows in the reduced context matrix for \
the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], "1"], "]"}], "\[Cross]", "\[CenterEllipsis]",
          "\[Cross]", 
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], 
            StyleBox["k", "TI"]], "]"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "[n_1] \\times \\cdots \\times [n_k]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ba9b5f10-1e24-420f-8da0-142a94581dc0"],
 ", in terms of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "[", "1", "]"}], ",", "...", ",", 
    RowBox[{"n", "[", "k", "]"}]}], TraditionalForm]],ExpressionUUID->
  "62cd430c-c409-4230-ad3e-29d265082d8f"],
 "\n",
 Cell[BoxData[
  RowBox[{"CodensityGrid", "[", "k", "]"}]], "InlineCode",ExpressionUUID->
  "f2054c77-bbee-4e0d-88fc-0e183c13c8d4"],
 " returns a formula for 1 minus the density of the reduced context matrix \
for the lattice of transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], "1"], "]"}], "\[Cross]", "\[CenterEllipsis]",
          "\[Cross]", 
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], 
            StyleBox["k", "TI"]], "]"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "[n_1] \\times \\cdots \\times [n_k]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "648b061c-c28f-4c7c-a744-aaee344342ac"],
 ", in terms of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "[", "1", "]"}], ",", "...", ",", 
    RowBox[{"n", "[", "k", "]"}]}], TraditionalForm]],ExpressionUUID->
  "b39c1fa7-7772-4b93-ad97-b24f72951936"],
 "\n",
 Cell[BoxData[
  RowBox[{"LimitingDensityGrid", "[", "k", "]"}]], "InlineCode",
  ExpressionUUID->"5c09899e-862a-4b72-ad06-c4ee69905058"],
 " returns the limit as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["n", "TI"], "1"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["k", "TI"]], "\[Rule]", "\[Infinity]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "n_1, \\dots, n_k \\to \\infty", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e11de7e1-0025-474c-b4da-1836871da726"],
 " of the density of the reduced context matrix for the the lattice of \
transfer systems on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], "1"], "]"}], "\[Cross]", "\[CenterEllipsis]",
          "\[Cross]", 
         RowBox[{"[", 
           SubscriptBox[
            StyleBox["n", "TI"], 
            StyleBox["k", "TI"]], "]"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "[n_1] \\times \\cdots \\times [n_k]", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f9663842-68a5-4d05-bba7-029c356a9956"]
}], "Text",
 CellChangeTimes->{{3.958239953445702*^9, 3.958240077032718*^9}, {
  3.9582401595257373`*^9, 3.95824024395595*^9}, {3.959278732567937*^9, 
  3.9592787482663116`*^9}, {3.959278797388372*^9, 3.959278852222026*^9}, {
  3.9592789157540283`*^9, 
  3.959278944583324*^9}},ExpressionUUID->"ddffd6b8-8b05-480d-a6d9-\
518205cc7f35"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NumZerosGrid", "[", "k_", "]"}], ":=", 
  RowBox[{"Sum", "@@", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Product", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"z", "[", "i", "]"}], "-", 
          RowBox[{"x", "[", "i", "]"}], "+", "1"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}], "-", 
       RowBox[{"Product", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"z", "[", "i", "]"}], "-", 
          RowBox[{"y", "[", "i", "]"}], "+", "1"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}]}], "}"}], "~", 
     "Join", "~", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", "i", "]"}], ",", "0", ",", 
         RowBox[{"n", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}], "~", "Join", "~", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"y", "[", "i", "]"}], ",", 
         RowBox[{"x", "[", "i", "]"}], ",", 
         RowBox[{"n", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}], "~", "Join", "~", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"z", "[", "i", "]"}], ",", 
         RowBox[{"y", "[", "i", "]"}], ",", 
         RowBox[{"n", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}]}], 
    ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NumRowsGrid", "[", "k_", "]"}], ":=", 
  RowBox[{"Sum", "@@", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Product", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"n", "[", "i", "]"}], "-", 
          RowBox[{"x", "[", "i", "]"}], "+", "1"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}], "-", "1"}], 
      "}"}], "~", "Join", "~", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", "i", "]"}], ",", "0", ",", 
         RowBox[{"n", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}]}], 
    ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CodensityGrid", "[", "k_", "]"}], ":=", 
   RowBox[{
    RowBox[{"NumZerosGrid", "[", "k", "]"}], "/", 
    RowBox[{
     RowBox[{"NumRowsGrid", "[", "k", "]"}], "^", "2"}]}]}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"LimitingDensityGrid", "[", "k_", "]"}], ":=", 
  RowBox[{"1", "-", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"CodensityGrid", "[", "k", "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"n", "[", "i", "]"}], "->", "Infinity"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "k"}], "}"}]}], "]"}]}], 
    "]"}]}]}]}], "Input",
 InitializationCell->True,
